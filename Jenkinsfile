stages {
    stage('Checkout') {
        steps {
            echo 'Cloning code from repository...'
        }
    }
    stage('Build') {
        steps {
            echo 'Building the application...'
        }
    }
    stage('Test') {
        steps {
            echo 'Running unit tests...'
        }
    }
    stage('Deploy') {
        steps {
            echo 'Deploying to staging environment...'
        }
    }
}